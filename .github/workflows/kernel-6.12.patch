- 	u32p_replace_bits(&tmp, aspm_support,
- 		PCIE_RC_CFG_PRIV1_LINK_CAPABILITY_ASPM_SUPPORT_MASK);
+ 	writel(tmp, base + PCIE_RC_CFG_PRIV1_LINK_CAPABILITY);
+ 
+ 	/* 'tmp' still holds the contents of PRIV1_LINK_CAPABILITY */
